# EdgeSignals Environment Variables
# Copy to .env and fill in values

# FRED API key for economic data (free from https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Stripe keys for payment processing (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Port (set automatically by Render, default 8000 for local dev)
PORT=8000
